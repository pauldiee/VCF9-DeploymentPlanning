---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { docHref } from '../../lib/path';
import { defaultSelection, selectedEpics, typeLabel, includedEpicList, AUTOMATION_PLACEMENTS, AUTOMATION_MODELS, NSX_CONNECTIVITY, SUPERVISOR_SIZES, STORAGE_TYPES } from '../../lib/deployment-plan';

const sel = defaultSelection();
const epics = selectedEpics(sel);
---

<BaseLayout
  title="Deployment Plan Export | VCF 9.1 Planning"
  description="Pick your VCF 9.1 deployment scope — management (stretched or not), Day-2 fleet, and one or more workload domains each stretched or not — and export the agile work breakdown as Markdown or a CSV that imports into Jira, Azure DevOps, or GitLab."
  active="06-deployment-plan"
>
  <article class="planx">
    <header class="planx__head">
      <p class="itq-eyebrow">Export tool</p>
      <h1>Deployment Plan Export</h1>
      <p class="planx__lede">
        Build your deployment scope below — pick <strong>NSX connectivity</strong> (Centralized/Distributed)
        and <strong>storage</strong> (vSAN ESA/OSA, NFS, FC), stretch the management domain or not, add the Day-2 fleet
        (with <strong>VCF Automation</strong>'s network placement + optional <strong>Avi</strong> load balancer),
        and add one or more <strong>workload domains</strong>, each independently <strong>non-stretched or stretched</strong>
        (a stretched domain gets its own hosts and its own vSAN witness). The plan filters to the exact
        epics and stories, then export it: <strong>Copy as Markdown</strong> for a wiki or PR, or
        <strong>download a CSV</strong> that imports into Jira, Azure DevOps, or GitLab. Mirrors the
        <a href={docHref('06-deployment-plan')}>Deployment Plan</a> page; everything runs in your browser.
      </p>
    </header>

    <section class="planx__controls">
      <fieldset>
        <legend>Scope</legend>
        <p class="planx__hint">Core epics (E1–E6, E10) always apply. Add the variants you need.</p>
        <label class="planx__sublabel">NSX connectivity
          <select id="selConnectivity">
            {NSX_CONNECTIVITY.map((c) => <option value={c.value}>{c.label}</option>)}
          </select>
        </label>
        <label class="planx__sublabel">Principal storage
          <select id="selStorage">
            {STORAGE_TYPES.map((s) => <option value={s.value}>{s.label}</option>)}
          </select>
        </label>
        <label class="planx__check"><input type="checkbox" id="optMgmtStretched" /> Stretch the management domain <span class="planx__tag">E7</span></label>
        <label class="planx__check"><input type="checkbox" id="optDay2" checked /> Day-2 fleet (Operations / Automation / Logs) <span class="planx__tag">E8</span></label>
        <div class="planx__sub" id="autoBlock">
          <label class="planx__check"><input type="checkbox" id="optAutoDeploy" checked /> Deploy VCF Automation <span class="planx__tag">E8.2</span></label>
          <label class="planx__sublabel">Deployment model
            <select id="selAutoModel">
              {AUTOMATION_MODELS.map((m) => <option value={m.value}>{m.label}</option>)}
            </select>
          </label>
          <label class="planx__sublabel">Network placement
            <select id="selAutoPlacement">
              {AUTOMATION_PLACEMENTS.map((p) => <option value={p.value}>{p.label}</option>)}
            </select>
          </label>
          <label class="planx__check"><input type="checkbox" id="optAutoAvi" /> Load-balance with Avi (management domain)</label>
        </div>
      </fieldset>

      <fieldset>
        <legend>Workload domains <button type="button" id="btnAddWld" class="planx__add">+ Add</button></legend>
        <p class="planx__hint">Each workload domain is its own epic (E9…). Tick <em>Stretched</em> for per-AZ host prep + a dedicated witness; tick <em>Supervisor</em> to add the vSphere Supervisor enablement story (needs Avi + connectivity first).</p>
        <div id="wldList"></div>
        <label class="planx__sublabel">Supervisor control-plane size (for enabled Supervisors)
          <select id="selSuperSize">
            {SUPERVISOR_SIZES.map((s) => <option value={s}>{s}</option>)}
          </select>
        </label>
      </fieldset>

      <p class="planx__summary" id="typeSummary">
        <strong>Scope: {typeLabel(sel)}</strong><br />
        Epics included: {includedEpicList(sel)}
      </p>

      <div class="planx__toolbar">
        <button type="button" id="btnCopyMd"><i class="fa-solid fa-clipboard-list" aria-hidden="true"></i> Copy Markdown</button>
        <button type="button" id="btnDlMd"><i class="fa-solid fa-download" aria-hidden="true"></i> Download .md</button>
        <button type="button" id="btnDlCsv"><i class="fa-solid fa-file-csv" aria-hidden="true"></i> Download CSV</button>
        <button type="button" id="btnCopyCsv"><i class="fa-solid fa-clipboard" aria-hidden="true"></i> Copy CSV</button>
        <span id="toolbarMsg" class="planx__toolbar-msg" role="status"></span>
      </div>
      <p class="planx__csvnote">
        CSV columns: <code>Issue Type, Summary, Parent, Owner, Acceptance Criteria, Reference</code> —
        one row per epic, story, and task; <code>Parent</code> references the parent's Summary so the
        importer can rebuild the hierarchy.
      </p>
    </section>

    <section class="planx__preview" id="preview">
      {
        epics.map((e) => (
          <div class="planx__epic">
            <h2>
              {e.id} — {e.title} <span class="planx__owner">Owner: {e.owner}</span>
            </h2>
            {e.ref && <p class="planx__ref">Ref: {e.ref}</p>}
            <ul>
              {e.stories.map((s) => (
                <li>
                  <strong>Story {s.id} — {s.title}.</strong>
                  <ul>
                    {s.tasks.map((t) => (
                      <li>{t}</li>
                    ))}
                    {s.acceptance && (
                      <li class="planx__accept">
                        <em>Acceptance:</em> {s.acceptance}
                      </li>
                    )}
                  </ul>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </section>

    <p class="planx__source">
      Source of truth: <a href={docHref('06-deployment-plan')}>docs/06-deployment-plan.md</a>.
      Host imaging + commissioning helper: <a href="https://github.com/pauldiee/VCFHostPreparation">VCFHostPreparation</a>.
      The CSV is a generic hierarchical import; map the columns to your tool's fields on import.
    </p>
  </article>
</BaseLayout>

<script>
  import {
    defaultSelection,
    selectedEpics,
    typeLabel,
    includedEpicList,
    buildMarkdown,
    buildCsv,
    type Selection,
    type Wld,
    type AutomationPlacement,
    type AutomationModel,
    type NsxConnectivity,
    type SupervisorSize,
    type StorageType,
  } from '../../lib/deployment-plan';

  const $ = (id: string) => document.getElementById(id)!;

  // WLD list is client-managed state (the checkboxes are read directly).
  let wlds: Wld[] = defaultSelection().wlds.map((w) => ({ ...w }));

  function readSel(): Selection {
    return {
      connectivity: (<HTMLSelectElement>$('selConnectivity')).value as NsxConnectivity,
      storage: (<HTMLSelectElement>$('selStorage')).value as StorageType,
      supervisorSize: (<HTMLSelectElement>$('selSuperSize')).value as SupervisorSize,
      mgmtStretched: (<HTMLInputElement>$('optMgmtStretched')).checked,
      day2: (<HTMLInputElement>$('optDay2')).checked,
      automation: {
        deploy: (<HTMLInputElement>$('optAutoDeploy')).checked,
        model: (<HTMLSelectElement>$('selAutoModel')).value as AutomationModel,
        placement: (<HTMLSelectElement>$('selAutoPlacement')).value as AutomationPlacement,
        aviLb: (<HTMLInputElement>$('optAutoAvi')).checked,
      },
      wlds: wlds.map((w) => ({ ...w })),
    };
  }

  // Grey out / disable the Automation sub-choices when Day-2 is off, and the
  // placement/Avi when Automation isn't being deployed.
  function syncAuto() {
    const day2 = (<HTMLInputElement>$('optDay2')).checked;
    const deploy = (<HTMLInputElement>$('optAutoDeploy')).checked;
    ($('autoBlock') as HTMLElement).style.opacity = day2 ? '1' : '0.45';
    (<HTMLInputElement>$('optAutoDeploy')).disabled = !day2;
    (<HTMLSelectElement>$('selAutoModel')).disabled = !day2 || !deploy;
    (<HTMLSelectElement>$('selAutoPlacement')).disabled = !day2 || !deploy;
    (<HTMLInputElement>$('optAutoAvi')).disabled = !day2 || !deploy;
  }

  function esc(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }
  function linkify(s: string): string {
    return esc(s).replace(/(https?:\/\/[^\s)]+)/g, '<a href="$1">$1</a>');
  }

  function renderWlds() {
    $('wldList').innerHTML = wlds
      .map(
        (w, i) => `
        <div class="planx__wld" data-i="${i}">
          <input class="planx__wldname" type="text" value="${esc(w.name)}" placeholder="wld${i + 1}" aria-label="Workload domain name" />
          <label class="planx__check"><input type="checkbox" class="planx__wldstretch" ${w.stretched ? 'checked' : ''} /> Stretched</label>
          <label class="planx__check"><input type="checkbox" class="planx__wldsuper" ${w.supervisor ? 'checked' : ''} /> Supervisor</label>
          <button type="button" class="planx__wlddel" aria-label="Remove workload domain" ${wlds.length <= 1 ? 'disabled' : ''}>×</button>
        </div>`
      )
      .join('');
  }

  function render() {
    const sel = readSel();
    $('typeSummary').innerHTML =
      `<strong>Scope: ${esc(typeLabel(sel))}</strong><br />Epics included: ${esc(includedEpicList(sel))}`;

    const html = selectedEpics(sel)
      .map((e) => {
        const stories = e.stories
          .map((s) => {
            const tasks = s.tasks.map((t) => `<li>${linkify(t)}</li>`).join('');
            const accept = s.acceptance
              ? `<li class="planx__accept"><em>Acceptance:</em> ${esc(s.acceptance)}</li>`
              : '';
            return `<li><strong>Story ${esc(s.id)} — ${esc(s.title)}.</strong><ul>${tasks}${accept}</ul></li>`;
          })
          .join('');
        const ref = e.ref ? `<p class="planx__ref">Ref: ${esc(e.ref)}</p>` : '';
        return `<div class="planx__epic"><h2>${esc(e.id)} — ${esc(e.title)} <span class="planx__owner">Owner: ${esc(e.owner)}</span></h2>${ref}<ul>${stories}</ul></div>`;
      })
      .join('');
    $('preview').innerHTML = html;
  }

  function toolbarMsg(msg: string) {
    const el = $('toolbarMsg');
    el.textContent = msg;
    setTimeout(() => { if (el.textContent === msg) el.textContent = ''; }, 2500);
  }

  function download(name: string, text: string, mime: string) {
    const blob = new Blob([text], { type: mime });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = name;
    a.click();
    URL.revokeObjectURL(a.href);
  }

  async function copy(text: string, ok: string) {
    try { await navigator.clipboard.writeText(text); toolbarMsg(ok); }
    catch { toolbarMsg('Copy failed (clipboard blocked)'); }
  }

  // WLD list events (delegated).
  $('btnAddWld').addEventListener('click', () => {
    wlds.push({ name: `wld0${wlds.length + 1}`, stretched: false, supervisor: false });
    renderWlds();
    render();
  });
  $('wldList').addEventListener('input', (e) => {
    const t = e.target as HTMLElement;
    const row = t.closest('.planx__wld') as HTMLElement | null;
    if (!row) return;
    const i = Number(row.dataset.i);
    if (t.classList.contains('planx__wldname')) wlds[i].name = (<HTMLInputElement>t).value;
    else if (t.classList.contains('planx__wldstretch')) wlds[i].stretched = (<HTMLInputElement>t).checked;
    else if (t.classList.contains('planx__wldsuper')) wlds[i].supervisor = (<HTMLInputElement>t).checked;
    render();
  });
  $('wldList').addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    if (!t.classList.contains('planx__wlddel')) return;
    const row = t.closest('.planx__wld') as HTMLElement | null;
    if (!row || wlds.length <= 1) return;
    wlds.splice(Number(row.dataset.i), 1);
    renderWlds();
    render();
  });

  $('selConnectivity').addEventListener('change', render);
  $('selStorage').addEventListener('change', render);
  $('selSuperSize').addEventListener('change', render);
  $('optMgmtStretched').addEventListener('change', render);
  $('optDay2').addEventListener('change', () => { syncAuto(); render(); });
  for (const id of ['optAutoDeploy', 'selAutoModel', 'selAutoPlacement', 'optAutoAvi']) {
    $(id).addEventListener('change', () => { syncAuto(); render(); });
  }

  $('btnCopyMd').addEventListener('click', () => copy(buildMarkdown(readSel()), 'Plan copied (Markdown)'));
  $('btnCopyCsv').addEventListener('click', () => copy(buildCsv(readSel()), 'CSV copied'));
  $('btnDlMd').addEventListener('click', () => {
    download('vcf9-deployment-plan.md', buildMarkdown(readSel()), 'text/markdown');
    toolbarMsg('Downloaded vcf9-deployment-plan.md');
  });
  $('btnDlCsv').addEventListener('click', () => {
    download('vcf9-deployment-plan.csv', buildCsv(readSel()), 'text/csv');
    toolbarMsg('Downloaded vcf9-deployment-plan.csv');
  });

  renderWlds();
  syncAuto();
  render();
</script>

<style is:global>
  .planx { max-width: 900px; }
  .planx__head h1 { margin: 0.2rem 0 0.6rem; }
  .planx__lede { color: var(--itq-royal-40); max-width: 72ch; }

  .planx fieldset {
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-sm);
    padding: 0.9rem 1rem 1rem;
    margin: 0 0 1rem;
  }
  .planx legend {
    font-weight: var(--fw-semibold); color: var(--itq-royal-blue); padding: 0 0.4rem;
    display: flex; align-items: center; gap: 0.6rem;
  }
  .planx__hint { font-size: 0.8rem; color: var(--itq-royal-40); margin: 0 0 0.6rem; }
  .planx__check {
    display: flex; align-items: center; gap: 0.5rem;
    color: var(--itq-royal-blue); font-size: 0.9rem; margin: 0.4rem 0;
  }
  .planx__check input[type='checkbox'] { width: auto; accent-color: var(--itq-orange); }
  .planx__tag {
    font-size: 0.7rem; color: var(--itq-royal-40); font-weight: var(--fw-semibold);
    border: var(--border-width) solid var(--border-default); border-radius: var(--radius-sm);
    padding: 0.05rem 0.4rem; margin-left: 0.2rem;
  }
  .planx__add {
    margin-left: auto; font-size: 0.75rem; padding: 0.2rem 0.55rem;
    border: var(--border-width) solid var(--itq-orange); color: var(--itq-orange);
    background: transparent; border-radius: var(--radius-sm); cursor: pointer;
  }
  .planx__add:hover { background: var(--itq-orange); color: var(--itq-white); }

  .planx__sub {
    margin: 0.2rem 0 0.2rem 1.5rem;
    padding: 0.4rem 0 0.2rem 0.7rem;
    border-left: 2px solid var(--border-default);
  }
  .planx__sublabel {
    display: block; font-size: 0.82rem; color: var(--itq-royal-40); margin: 0.4rem 0;
  }
  .planx__sublabel select {
    display: block; margin-top: 0.2rem; font: inherit; font-size: 0.85rem;
    padding: 0.35rem 0.5rem; border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-sm); background: var(--itq-white); max-width: 22rem;
  }
  .planx__sublabel select:disabled, .planx__sub input:disabled { cursor: not-allowed; }

  .planx__wld {
    display: flex; align-items: center; gap: 0.6rem;
    background: var(--itq-mist); border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-sm); padding: 0.45rem 0.55rem; margin-bottom: 0.45rem;
  }
  .planx__wldname {
    flex: 1; font: inherit; font-size: 0.85rem; padding: 0.35rem 0.5rem;
    border: var(--border-width) solid var(--border-default); border-radius: var(--radius-sm);
    background: var(--itq-white);
  }
  .planx__wld .planx__check { margin: 0; flex: none; }
  .planx__wlddel {
    flex: none; width: 1.7rem; height: 1.7rem; line-height: 1; font-size: 1rem; cursor: pointer;
    border: var(--border-width) solid var(--border-default); background: var(--itq-white);
    color: var(--itq-royal-blue); border-radius: var(--radius-sm);
  }
  .planx__wlddel:hover:not([disabled]) { background: var(--itq-orange); color: var(--itq-white); border-color: var(--itq-orange); }
  .planx__wlddel[disabled] { opacity: 0.4; cursor: not-allowed; }

  .planx__summary {
    margin: 0 0 0.8rem; padding: 0.55rem 0.7rem;
    background: var(--itq-mist); border-radius: var(--radius-sm);
    font-size: 0.85rem; color: var(--itq-royal-blue); line-height: 1.5;
  }
  .planx__toolbar { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; margin: 0.3rem 0 0.5rem; }
  .planx__toolbar button {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font: inherit; font-size: 0.8rem; padding: 0.35rem 0.75rem;
    border: var(--border-width) solid var(--border-default); border-radius: var(--radius-sm);
    background: var(--itq-white); color: var(--itq-royal-blue); cursor: pointer;
  }
  .planx__toolbar button:hover { border-color: var(--itq-orange); color: var(--itq-orange); }
  .planx__toolbar-msg { font-size: 0.78rem; color: var(--itq-orange); font-weight: var(--fw-semibold); }
  .planx__csvnote { font-size: 0.78rem; color: var(--itq-royal-40); margin: 0 0 1rem; max-width: 72ch; }
  .planx__csvnote code { font-size: 0.72rem; }

  .planx__preview { border-top: var(--border-width) solid var(--border-default); padding-top: 0.8rem; }
  .planx__epic { margin-bottom: 1.3rem; }
  .planx__epic h2 {
    font-size: 1.05rem; margin: 0.6rem 0 0.3rem; color: var(--itq-royal-blue);
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.6rem;
  }
  .planx__owner { font-size: 0.75rem; font-weight: var(--fw-semibold); color: var(--itq-orange); }
  .planx__ref { font-size: 0.78rem; color: var(--itq-royal-40); margin: 0 0 0.4rem; }
  .planx__epic ul { margin: 0.2rem 0 0; }
  .planx__epic > ul > li { margin-bottom: 0.35rem; }
  .planx__epic ul ul { margin: 0.15rem 0 0.4rem; }
  .planx__accept { color: var(--itq-royal-40); font-size: 0.85rem; }
  .planx__source { font-size: 0.78rem; color: var(--itq-royal-40); margin-top: 2rem; border-top: var(--border-width) solid var(--border-default); padding-top: 0.8rem; }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { OPTIONS, WORKBOOK_REVISION } from '../../lib/mgmt-sizing';

// Server-render the <option> lists from the shared engine so the dropdowns
// never drift from the calculation tables.
const opt = (values: readonly string[]) => values;
---

<BaseLayout
  title="Management Domain Sizing & Fit Check — VCF 9.1 Planning"
  description="Interactive VCF 9.1 management-domain sizing calculator with a cluster fit check: does your proposed host count and spec fit the fleet at N-1?"
  active="04-sizing"
>
  <article class="sizer">
    <header class="sizer__head">
      <p class="itq-eyebrow">Sizing tool</p>
      <h1>Management Domain Sizing &amp; Fit Check</h1>
      <p class="sizer__lede">
        Reproduces the Broadcom <em>Planning &amp; Preparation Workbook</em>
        (<strong>{WORKBOOK_REVISION}</strong>) <em>Management Domain Sizing</em> sheet, and adds the
        check the spreadsheet lacks: enter the cluster you intend to build and see whether the
        fleet <strong>fits at N-1</strong> &mdash; and where the headroom is. Everything runs in your
        browser; nothing is sent anywhere.
      </p>
    </header>

    <div class="sizer__grid">
      <!-- ================= INPUTS ================= -->
      <section class="sizer__inputs">
        <fieldset>
          <legend>Deployment profile</legend>
          <label>Deployment model
            <select id="deploymentModel">{opt(OPTIONS.deploymentModel).map((v) => <option>{v}</option>)}</select>
          </label>
          <label>Deployment size
            <select id="deploymentSize">{opt(OPTIONS.deploymentSize).map((v) => <option>{v}</option>)}</select>
          </label>
          <p class="sizer__hint">Simple deploys at Small only; High Availability at Medium or Large.</p>
          <label>Instance model
            <select id="instanceModel">{opt(OPTIONS.instanceModel).map((v) => <option>{v}</option>)}</select>
          </label>
          <label>Principal storage
            <select id="storageType">{opt(OPTIONS.storageType).map((v) => <option>{v}</option>)}</select>
          </label>
        </fieldset>

        <fieldset>
          <legend>Proposed cluster &amp; host spec</legend>
          <label>Cluster type
            <select id="clusterType">{opt(OPTIONS.clusterType).map((v) => <option>{v}</option>)}</select>
          </label>
          <label>Number of hosts
            <input id="proposedHosts" type="number" min="1" step="1" />
          </label>
          <label>Cores per host
            <input id="coresPerHost" type="number" min="1" step="1" />
          </label>
          <label>RAM per host (GB)
            <input id="ramPerHost" type="number" min="1" step="1" />
          </label>
          <div id="vsanCapacity">
            <label><span id="capacityDisksText">Capacity disks per host</span>
              <input id="capacityDisksPerHost" type="number" min="0" step="1" />
            </label>
            <label>Capacity disk size (GB)
              <input id="capacityDiskSizeGb" type="number" min="0" step="10" />
            </label>
            <p class="sizer__hint" id="capacityHint"></p>
            <p class="sizer__hint" id="perHostRawOut"></p>
          </div>
          <label id="externalCapacity" hidden>Available datastore capacity (GB)
            <input id="externalStorageGb" type="number" min="0" step="100" />
          </label>
          <label>CPU oversubscription (X:1)
            <input id="cpuOver" type="number" min="1" step="0.5" />
          </label>
          <label>RAM oversubscription (X:1)
            <input id="ramOver" type="number" min="1" step="0.5" />
          </label>
          <label>Host + operations reserve (%)
            <input id="reservePct" type="number" min="0" step="1" />
          </label>
          <label>Storage growth (%)
            <input id="growthPct" type="number" min="0" step="1" />
          </label>
        </fieldset>

        <fieldset>
          <legend>Management components</legend>
          <p class="sizer__hint" id="derivedSizes"></p>
          <label>NSX Global Manager
            <select id="nsxGmSize">
              <option>Excluded</option>{opt(OPTIONS.nsxManagerSize).map((v) => <option>{v}</option>)}
            </select>
          </label>
          <label>NSX Edges
            <select id="nsxEdgeSize">{opt(OPTIONS.nsxEdgeSize).map((v) => <option>{v}</option>)}</select>
          </label>
          <label>AVI Load Balancer
            <select id="aviSize">{opt(OPTIONS.aviSize).map((v) => <option>{v}</option>)}</select>
          </label>
          <label>Security Services Platform
            <select id="sspSize">{opt(OPTIONS.sspSize).map((v) => <option>{v}</option>)}</select>
          </label>
          <label>VCF Operations for Networks
            <select id="opsNetSize">{opt(OPTIONS.opsNetSize).map((v) => <option>{v}</option>)}</select>
          </label>
          <label class="sizer__check"><input id="vcfOps" type="checkbox" /> VCF Operations</label>
          <label class="sizer__check"><input id="vcfOpsCollector" type="checkbox" /> Cloud Proxy (Ops collector)</label>
          <label class="sizer__check"><input id="vcfAutomation" type="checkbox" /> VCF Automation</label>
        </fieldset>

        <fieldset>
          <legend>Workload domains
            <button type="button" id="addWld" class="sizer__add">+ Add workload domain</button>
          </legend>
          <p class="sizer__hint">Each workload domain's vCenter and (dedicated) NSX Managers run inside the
            management domain, so they add to its footprint.</p>
          <div id="wldList"></div>
        </fieldset>
      </section>

      <!-- ================= RESULTS ================= -->
      <section class="sizer__results">
        <div id="verdict" class="verdict"></div>

        <h2>Fit against your cluster</h2>
        <table class="sizer__table" id="fitTable">
          <thead><tr><th>Dimension</th><th>Fleet needs</th><th>Cluster offers</th><th>Headroom</th><th></th></tr></thead>
          <tbody></tbody>
        </table>
        <p class="sizer__hint">CPU and RAM are checked against the tolerated failure: <strong>N-1</strong> (one host)
          for a standard cluster, or <strong>N/2</strong> (the surviving AZ must run everything) for a stretched
          cluster. Storage rebuild is covered by the reserve %, and stretched mirrors a full copy per AZ.</p>

        <h2>Fleet requirement</h2>
        <dl class="sizer__stats" id="stats"></dl>

        <details class="sizer__detail">
          <summary>Component footprint (<span id="compCount">0</span> line items)</summary>
          <table class="sizer__table" id="compTable">
            <thead><tr><th>Component</th><th>Nodes</th><th>vCPU</th><th>RAM&nbsp;GB</th><th>Disk&nbsp;GB</th></tr></thead>
            <tbody></tbody>
          </table>
        </details>

        <details class="sizer__detail">
          <summary>vSAN raw capacity breakdown</summary>
          <dl class="sizer__stats" id="vsanTable"></dl>
        </details>
      </section>
    </div>

    <p class="sizer__source">
      Figures transcribed from <code>reference/vcf-9.1-planning-and-preparation-workbook.xlsx</code>
      ({WORKBOOK_REVISION}), sheet <em>Management Domain Sizing</em>. This is a planning aid &mdash;
      always confirm the final numbers against the official workbook for the customer's revision.
    </p>
  </article>
</BaseLayout>

<script>
  import { OPTIONS, defaultState, compute, type SizingState, type WorkloadDomain } from '../../lib/mgmt-sizing';

  const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;
  const state: SizingState = defaultState();

  const selOptions = (values: readonly string[], selected: string) =>
    values.map((v) => `<option${v === selected ? ' selected' : ''}>${v}</option>`).join('');

  // ---- bind top-level inputs to state ----
  const numIds = ['proposedHosts', 'coresPerHost', 'ramPerHost', 'capacityDisksPerHost', 'capacityDiskSizeGb', 'externalStorageGb', 'cpuOver', 'ramOver', 'reservePct', 'growthPct'] as const;
  const selIds = ['deploymentModel', 'deploymentSize', 'instanceModel', 'storageType', 'clusterType', 'nsxGmSize', 'nsxEdgeSize', 'aviSize', 'sspSize', 'opsNetSize'] as const;
  const chkIds = ['vcfOps', 'vcfOpsCollector', 'vcfAutomation'] as const;

  function hydrate() {
    for (const id of numIds) ($(id) as HTMLInputElement).value = String((state as any)[id]);
    for (const id of selIds) ($(id) as HTMLSelectElement).value = String((state as any)[id]);
    for (const id of chkIds) ($(id) as HTMLInputElement).checked = Boolean((state as any)[id]);
  }

  function readInputs() {
    for (const id of numIds) (state as any)[id] = parseFloat(($(id) as HTMLInputElement).value) || 0;
    for (const id of selIds) (state as any)[id] = ($(id) as HTMLSelectElement).value;
    for (const id of chkIds) (state as any)[id] = ($(id) as HTMLInputElement).checked;
  }

  // ---- workload domain repeater ----
  function renderWlds() {
    const host = $('wldList');
    host.innerHTML = '';
    state.workloadDomains.forEach((w, i) => {
      const row = document.createElement('div');
      row.className = 'wld';
      row.innerHTML = `
        <input class="wld__name" data-i="${i}" data-k="name" placeholder="WLD ${i + 1} name" value="${w.name}" />
        <select data-i="${i}" data-k="vcenterSize" title="vCenter size">${selOptions(OPTIONS.vcenterSize, w.vcenterSize)}</select>
        <select data-i="${i}" data-k="vcenterStorage" title="vCenter storage">${selOptions(OPTIONS.vcenterStorage, w.vcenterStorage)}</select>
        <select data-i="${i}" data-k="nsxModel" title="NSX model">${selOptions(OPTIONS.nsxModel, w.nsxModel)}</select>
        <select data-i="${i}" data-k="nsxSize" title="NSX Manager size">${selOptions(OPTIONS.nsxManagerSize, w.nsxSize)}</select>
        <select data-i="${i}" data-k="gm" title="Global Manager">${selOptions(OPTIONS.gm, w.gm)}</select>
        <button type="button" class="wld__del" data-i="${i}" aria-label="Remove">&times;</button>`;
      host.appendChild(row);
    });
    host.querySelectorAll<HTMLElement>('input,select').forEach((el) =>
      el.addEventListener('input', (e) => {
        const t = e.target as HTMLInputElement;
        const i = Number(t.dataset.i);
        (state.workloadDomains[i] as any)[t.dataset.k as keyof WorkloadDomain] = t.value;
        recalc();
      }),
    );
    host.querySelectorAll<HTMLButtonElement>('.wld__del').forEach((b) =>
      b.addEventListener('click', () => {
        state.workloadDomains.splice(Number(b.dataset.i), 1);
        renderWlds();
        recalc();
      }),
    );
  }

  $('addWld').addEventListener('click', () => {
    state.workloadDomains.push({ name: '', vcenterSize: 'Small', vcenterStorage: 'Default', nsxModel: 'Dedicated - HA Cluster', nsxSize: 'Medium', gm: 'None' });
    renderWlds();
    recalc();
  });

  // ---- deployment size is constrained by the model (workbook cell O23):
  //   Simple -> Small only; High Availability -> Medium or Large.
  const sizeByModel: Record<string, string[]> = {
    Simple: ['Small'],
    'High Availability': ['Medium', 'Large'],
  };
  let lastModel = '';
  function syncSizeOptions() {
    const model = ($('deploymentModel') as HTMLSelectElement).value;
    const allowed = sizeByModel[model] ?? [...OPTIONS.deploymentSize];
    const sel = $('deploymentSize') as HTMLSelectElement;
    const current = allowed.includes(sel.value) ? sel.value : allowed[0];
    sel.innerHTML = selOptions(allowed, current);
    sel.disabled = allowed.length < 2;
    state.deploymentSize = current;
  }

  // ---- storage capacity input depends on the storage type ----
  let lastStorage = '';
  function syncStorageInputs() {
    const t = ($('storageType') as HTMLSelectElement).value;
    const vsan = t === 'vSAN-ESA' || t === 'vSAN-OSA';
    ($('vsanCapacity') as HTMLElement).hidden = !vsan;
    ($('externalCapacity') as HTMLElement).hidden = vsan;
    if (vsan) {
      $('capacityDisksText').textContent = t === 'vSAN-ESA' ? 'Storage devices per host' : 'Capacity disks per host';
      $('capacityHint').textContent = t === 'vSAN-ESA'
        ? 'ESA: every NVMe device in the storage pool counts toward capacity.'
        : 'OSA: capacity-tier disks only — the cache device per disk group does not add usable capacity.';
    }
  }

  // ---- rendering ----
  const gb = (n: number) => n.toLocaleString('en-US');
  const pct = (n: number) => (n === Infinity ? '—' : `${n >= 0 ? '+' : ''}${n.toFixed(0)}%`);

  function recalc() {
    const model = ($('deploymentModel') as HTMLSelectElement).value;
    if (model !== lastModel) {
      lastModel = model;
      syncSizeOptions();
    }
    const storage = ($('storageType') as HTMLSelectElement).value;
    if (storage !== lastStorage) {
      lastStorage = storage;
      syncStorageInputs();
    }
    readInputs();
    const r = compute(state);

    // verdict banner
    const v = $('verdict');
    v.className = `verdict ${r.fit.overall ? 'verdict--ok' : 'verdict--bad'}`;
    const survives = state.clusterType === 'Standard' ? 'one host failure' : 'a full AZ (site) failure';
    v.innerHTML = r.fit.overall
      ? `<strong>Fits.</strong> ${state.proposedHosts} × host survives ${survives} with room to spare. Tightest dimension: ${r.fit.binding}.`
      : `<strong>Does not fit.</strong> Shortfall on <strong>${r.fit.binding}</strong> (survivability basis: ${r.survivorBasis}). Minimum hosts for this fleet &amp; spec: <strong>${r.requiredHosts}</strong>.`;

    // fit table
    const rows: Array<[string, string, string, ReturnType<typeof compute>['fit']['cpu']]> = [
      [`CPU (vCPU, ${r.survivorBasis})`, `${gb(r.fit.cpu.required)}`, `${gb(r.fit.cpu.available)}`, r.fit.cpu],
      [`RAM (GB, ${r.survivorBasis})`, `${gb(r.fit.ram.required)}`, `${gb(r.fit.ram.available)}`, r.fit.ram],
      ['vSAN raw (GB)', `${gb(r.fit.storage.required)}`, `${gb(r.fit.storage.available)}`, r.fit.storage],
      ['Host count', `${r.fit.hosts.required}`, `${r.fit.hosts.available}`, r.fit.hosts],
    ];
    $('fitTable').querySelector('tbody')!.innerHTML = rows
      .map(([label, req, avail, d]) =>
        `<tr class="${d.fits ? 'ok' : 'bad'}"><td>${label}</td><td>${req}</td><td>${avail}</td><td>${pct(d.headroomPct)}</td><td>${d.fits ? '✓' : '✗'}</td></tr>`,
      )
      .join('');

    // fleet stats
    $('stats').innerHTML = [
      ['Total nodes (VMs)', gb(r.totals.nodes)],
      ['Total vCPU', gb(r.totals.cpu)],
      ['Total RAM', `${gb(r.totals.ram)} GB`],
      ['Total VM disk', `${gb(r.totals.disk)} GB`],
      ['Minimum hosts', `${r.requiredHosts}`],
      ['vCPU / host (N-1)', r.perHostN1 ? gb(r.perHostN1.cpu) : '—'],
      ['RAM / host (N-1)', r.perHostN1 ? `${gb(r.perHostN1.ram)} GB` : '—'],
      ['Storage / host (N-1)', r.perHostN1 ? `${gb(r.perHostN1.storage)} GB` : '—'],
    ].map(([k, val]) => `<div><dt>${k}</dt><dd>${val}</dd></div>`).join('');

    // component table
    $('compCount').textContent = String(r.components.length);
    $('compTable').querySelector('tbody')!.innerHTML = r.components
      .map((c) => `<tr><td>${c.name}</td><td>${c.nodes}</td><td>${gb(c.cpu)}</td><td>${gb(c.ram)}</td><td>${gb(c.disk)}</td></tr>`)
      .join('');

    // derived (profile-fixed) component sizes
    $('derivedSizes').innerHTML = `Fixed by the deployment profile: management vCenter <strong>${r.derived.vcenterSize}</strong> ` +
      `(<strong>${r.derived.vcenterStorage}</strong> storage), NSX Local Manager <strong>${r.derived.nsxManagerSize}</strong>. ` +
      `The options below are your genuine choices.`;

    // derived per-host raw readout
    const rawOut = $('perHostRawOut');
    rawOut.textContent = r.perHostRaw > 0
      ? `= ${gb(r.perHostRaw)} GB raw per host → ${gb(r.storageAvailable)} GB across ${state.proposedHosts} hosts.`
      : '';

    // vSAN breakdown
    $('vsanTable').innerHTML = [
      ['VM capacity (disk)', `${gb(r.vsan.vmCapacity)} GB`],
      ['Swap reservation', `${gb(r.vsan.swap)} GB`],
      ['Interim total', `${gb(r.vsan.interim)} GB`],
      ['After FTT redundancy', `${gb(r.vsan.redundancy)} GB`],
      ['After rebuild + ops reserve', `${gb(r.vsan.reserve)} GB`],
      ['After growth', `${gb(r.vsan.growth)} GB`],
      ['Raw capacity required', `${gb(r.vsan.raw)} GB`],
    ].map(([k, val]) => `<div><dt>${k}</dt><dd>${val}</dd></div>`).join('');
  }

  for (const id of [...numIds, ...selIds, ...chkIds]) $(id).addEventListener('input', recalc);
  hydrate();
  renderWlds();
  recalc();
</script>

<style is:global>
  .sizer { max-width: 1100px; }
  .sizer__head h1 { margin: 0.2rem 0 0.6rem; }
  .sizer__lede { color: var(--itq-royal-40); max-width: 70ch; }
  .sizer__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-6, 1.5rem);
    align-items: start;
  }
  @media (max-width: 900px) { .sizer__grid { grid-template-columns: 1fr; } }

  .sizer fieldset {
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-sm);
    padding: 0.9rem 1rem 1rem;
    margin: 0 0 1rem;
  }
  .sizer legend {
    font-weight: var(--fw-semibold);
    color: var(--itq-royal-blue);
    padding: 0 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .sizer label { display: block; font-size: 0.85rem; margin: 0.45rem 0; color: var(--itq-royal-40); }
  .sizer label.sizer__check { display: flex; align-items: center; gap: 0.5rem; color: var(--itq-royal-blue); }
  .sizer select, .sizer input[type='number'], .sizer input.wld__name {
    display: block;
    width: 100%;
    margin-top: 0.2rem;
    padding: 0.4rem 0.5rem;
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-sm);
    font: inherit;
    background: var(--itq-white);
  }
  .sizer input[type='checkbox'] { width: auto; accent-color: var(--itq-orange); }
  .sizer__add {
    margin-left: auto;
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border: var(--border-width) solid var(--itq-orange);
    color: var(--itq-orange);
    background: transparent;
    border-radius: var(--radius-sm);
    cursor: pointer;
  }
  .sizer__add:hover { background: var(--itq-orange); color: var(--itq-white); }
  .sizer__hint { font-size: 0.78rem; color: var(--itq-royal-40); margin: 0.3rem 0 0.6rem; }

  .wld {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.6fr 1fr 1fr auto;
    gap: 0.35rem;
    margin-bottom: 0.4rem;
    align-items: center;
  }
  .wld select, .wld input { margin-top: 0; font-size: 0.8rem; padding: 0.3rem; }
  .wld__del {
    border: none; background: var(--itq-mist); color: var(--itq-royal-blue);
    border-radius: var(--radius-sm); width: 1.7rem; height: 1.7rem; cursor: pointer; font-size: 1rem;
  }
  .wld__del:hover { background: var(--itq-orange); color: var(--itq-white); }

  .sizer__results { position: sticky; top: calc(var(--header-h) + 1rem); }
  .verdict {
    padding: 0.8rem 1rem;
    border-radius: var(--radius-sm);
    border-left: 4px solid;
    margin-bottom: 1.2rem;
    font-size: 0.95rem;
  }
  .verdict--ok { background: #e9f6ec; border-color: #2e9e4f; color: #1c5c30; }
  .verdict--bad { background: #fdecec; border-color: #d13b3b; color: #8a2222; }

  .sizer__results h2 { font-size: 1.05rem; margin: 1.3rem 0 0.5rem; color: var(--itq-royal-blue); }
  .sizer__table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
  .sizer__table th, .sizer__table td {
    text-align: right; padding: 0.35rem 0.5rem;
    border-bottom: var(--border-width) solid var(--border-default);
  }
  .sizer__table th:first-child, .sizer__table td:first-child { text-align: left; }
  .sizer__table thead th { color: var(--itq-royal-40); font-weight: var(--fw-semibold); }
  #fitTable tr.ok td { color: #1c5c30; }
  #fitTable tr.bad td { color: #8a2222; font-weight: var(--fw-semibold); }

  .sizer__stats { display: grid; grid-template-columns: 1fr 1fr; gap: 0.4rem 1rem; margin: 0.4rem 0; }
  .sizer__stats div { display: flex; justify-content: space-between; border-bottom: 1px dotted var(--border-default); padding: 0.2rem 0; }
  .sizer__stats dt { color: var(--itq-royal-40); font-size: 0.82rem; margin: 0; }
  .sizer__stats dd { margin: 0; font-weight: var(--fw-semibold); font-size: 0.85rem; }

  .sizer__detail { margin-top: 1rem; border: var(--border-width) solid var(--border-default); border-radius: var(--radius-sm); padding: 0.3rem 0.8rem; }
  .sizer__detail summary { cursor: pointer; font-weight: var(--fw-semibold); color: var(--itq-royal-blue); padding: 0.4rem 0; font-size: 0.9rem; }
  .sizer__source { font-size: 0.78rem; color: var(--itq-royal-40); margin-top: 2rem; border-top: var(--border-width) solid var(--border-default); padding-top: 0.8rem; }
</style>

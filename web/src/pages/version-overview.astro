---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/vcf-versions.json';

// Data is refreshed daily by web/scripts/scrape-versions.mjs (a scheduled GitHub Action
// commits it back to main, which rebuilds Pages). See issue #179.
const { _updated, _sourceErrors, components } = data;

// Group by category, preserving manifest order within each group. Rows with a `parent`
// (the VCF Operations sub-components, #180) are rendered indented beneath their parent row as a
// visual grouping - they are independently-versioned components, not internal parts of one (#185).
const order = ['Core', 'Operations', 'Automation', 'Management', 'Add-ons'];
const groups = order
  .map((cat) => {
    const rows = components.filter((c) => c.category === cat);
    const childrenOf = (key) => rows.filter((c) => c.parent === key);
    const ordered = [];
    for (const c of rows.filter((c) => !c.parent)) {
      ordered.push({ ...c, child: false });
      for (const ch of childrenOf(c.key)) ordered.push({ ...ch, child: true });
    }
    return { cat, rows: ordered };
  })
  .filter((g) => g.rows.length);

const fmtDate = (iso) =>
  iso ? new Date(iso + 'T00:00:00Z').toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric', timeZone: 'UTC' }) : '';
---

<BaseLayout
  title="VCF 9.1 Version Overview"
  active="version-overview"
  description="Current latest version and build per VMware Cloud Foundation 9.1 component, refreshed daily from Broadcom."
>
  <article class="prose">
    <p class="doc-eyebrow itq-eyebrow">Reference</p>
    <h1>VCF 9.1 Version Overview</h1>

    <p>
      The current latest version and build for each VMware Cloud Foundation 9.1 component. In 9.1,
      components patch <strong>per component and asynchronously</strong> (Express Patches), so a
      single point-in-time table drifts within weeks. This one is refreshed automatically from
      Broadcom, so it stays honest as a one-glance &ldquo;what&rsquo;s current&rdquo; reference
      during planning.
    </p>

    <p class="vo-updated">
      <i class="fa-solid fa-clock-rotate-left" aria-hidden="true"></i>
      Last updated <strong>{fmtDate(_updated)}</strong>
      <span class="vo-updated__note">&middot; refreshed daily from Broadcom</span>
    </p>

    {
      _sourceErrors && _sourceErrors.length > 0 && (
        <p class="vo-warn">
          <i class="fa-solid fa-triangle-exclamation" aria-hidden="true" />
          {_sourceErrors.length} source(s) could not be read on the last run; those rows show the
          last known value: {_sourceErrors.map((e) => e.key).join(', ')}.
        </p>
      )
    }

    {
      groups.map((g) => (
        <>
          <h2 class="vo-cat">{g.cat}</h2>
          {g.cat === 'Add-ons' && (
            <p class="vo-note">
              Optional components, <strong>not part of the base VCF 9.1 BOM</strong>. Each patches on
              its own cadence in its own release-notes tree. Avi Load Balancer publishes no build
              number, so its Build column shows &ldquo;N/A&rdquo;.
            </p>
          )}
          <figure class="table-scroll vo-table">
            <table>
              <thead>
                <tr>
                  <th>Component</th>
                  <th>Latest version</th>
                  <th>Build</th>
                  <th>Released</th>
                  <th>Source</th>
                </tr>
              </thead>
              <tbody>
                {g.rows.map((c) => (
                  <tr class={c.child ? 'vo-child' : undefined}>
                    <td class="vo-name">{c.name}</td>
                    <td class="vo-ver">
                      {c.version ?? ''}
                      {c.patched === false && <span class="vo-pill">GA</span>}
                    </td>
                    <td class="vo-build">{c.build ?? 'N/A'}</td>
                    <td>{fmtDate(c.releaseDate)}</td>
                    <td>
                      {c.sourceUrl && (
                        <a href={c.sourceUrl} target="_blank" rel="noopener">
                          Release notes <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true" />
                        </a>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </figure>
        </>
      ))
    }

    <blockquote>
      <p>
        <strong>Always confirm with Broadcom before advising a build.</strong> Patch cadence is
        high and components move independently. Rows marked <span class="vo-pill">GA</span> have no
        Express Patch yet, so they run at their general-availability build. The VCF Operations
        services listed under Management &mdash; Orchestrator, Log Management, Real-Time Metrics and
        its Store &mdash; are independently-versioned components of that product family, each with
        its own build; they currently happen to be aligned on the same Express Patch. vCenter is
        read from its build-number KB, the core fleet from the Broadcom TechDocs patch-release tree,
        and each add-on from its own release-notes tree.
      </p>
    </blockquote>

    <p class="vo-src">
      Sources: <a href={data._sources.techdocs} target="_blank" rel="noopener">TechDocs patch releases</a>
      &middot; <a href="https://knowledge.broadcom.com/external/article/326316" target="_blank" rel="noopener">vCenter build KB</a>.
      Generated by <code>web/scripts/scrape-versions.mjs</code>.
    </p>
  </article>
</BaseLayout>

<style>
  .vo-updated {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: var(--space-3) var(--space-4);
    background: var(--itq-mist);
    border-left: 4px solid var(--itq-orange);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: var(--fs-small);
  }
  .vo-updated__note { color: var(--itq-royal-40); }

  .vo-warn {
    padding: var(--space-3) var(--space-4);
    background: #fff6f5;
    border-left: 4px solid var(--itq-orange);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: var(--fs-small);
  }
  .vo-warn i { color: var(--itq-orange); margin-right: 0.4rem; }

  .vo-cat {
    margin-top: var(--space-7);
    font-size: var(--fs-h4, 1.1rem);
    color: var(--itq-royal-blue);
  }
  .vo-table { margin-top: var(--space-3); }
  .vo-name { font-weight: var(--fw-semibold); white-space: normal; }
  .vo-ver { white-space: nowrap; }
  .vo-build { font-family: var(--font-mono); white-space: nowrap; }

  /* VCF Operations sub-components (#180): indented sub-rows under their parent (visual grouping). */
  .vo-child .vo-name {
    font-weight: var(--fw-regular);
    color: var(--itq-royal-40);
    padding-left: 1.9rem;
    position: relative;
  }
  .vo-child .vo-name::before {
    content: "\21B3"; /* downwards arrow with tip rightwards */
    position: absolute;
    left: 0.7rem;
    color: var(--itq-royal-40);
  }
  .vo-child .vo-ver, .vo-child .vo-build { color: var(--itq-royal-40); }

  .vo-note {
    padding: var(--space-3) var(--space-4);
    background: var(--itq-mist);
    border-left: 4px solid var(--itq-royal-40);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: var(--fs-small);
    margin-top: var(--space-2);
  }

  .vo-pill {
    display: inline-block;
    margin-left: 0.4rem;
    padding: 0.05rem 0.4rem;
    font-size: 0.7rem;
    font-weight: var(--fw-semibold);
    letter-spacing: 0.03em;
    color: var(--itq-royal-blue);
    background: var(--itq-light-blue);
    border-radius: var(--radius-sm);
    vertical-align: middle;
  }
  .vo-src { font-size: var(--fs-small); color: var(--itq-royal-40); }
</style>

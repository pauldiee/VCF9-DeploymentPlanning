---
import { NAV } from '../nav';
import { docHref as href } from '../lib/path';

interface Props {
  active?: string;
}
const { active } = Astro.props;
---

<aside class="sidebar" aria-label="Planning docs">
  <p class="sidebar__eyebrow itq-eyebrow">Planning flow</p>
  <nav>
    <ol class="sidebar__list">
      {
        NAV.map((item) => (
          <li>
            <a
              class:list={['sidebar__link', { 'is-active': active === item.slug }]}
              href={href(item.slug)}
              aria-current={active === item.slug ? 'page' : undefined}
            >
              <i class={`fa-solid fa-${item.icon} sidebar__icon`} aria-hidden="true" />
              <span class="sidebar__text">
                <span class="sidebar__step">{item.step}</span>
                <span class="sidebar__label">{item.label}</span>
              </span>
            </a>
          </li>
        ))
      }
    </ol>
  </nav>
</aside>

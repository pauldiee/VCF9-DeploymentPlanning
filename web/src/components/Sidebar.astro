---
import { NAV } from '../nav';
import { docHref as href, withBase } from '../lib/path';

interface Props {
  active?: string;
}
const { active } = Astro.props;
const sampleHref = withBase('samples/01-network-dns-plan-rainpole/');
const sizerHref = withBase('tools/mgmt-sizing/');
const planExportHref = withBase('tools/deployment-plan/');
const planTrackerHref = withBase('tools/plan-tracker/');
---

<aside class="sidebar" aria-label="Planning docs">
  <p class="sidebar__eyebrow itq-eyebrow">Planning flow</p>
  <nav>
    <ol class="sidebar__list">
      {
        NAV.map((item) => (
          <li>
            <a
              class:list={['sidebar__link', { 'is-active': active === item.slug }]}
              href={href(item.slug)}
              aria-current={active === item.slug ? 'page' : undefined}
            >
              <i class={`fa-solid fa-${item.icon} sidebar__icon`} aria-hidden="true" />
              <span class="sidebar__text">
                <span class="sidebar__step">{item.step}</span>
                <span class="sidebar__label">{item.label}</span>
              </span>
            </a>
          </li>
        ))
      }
    </ol>
  </nav>

  <p class="sidebar__eyebrow itq-eyebrow sidebar__eyebrow--spaced">Tools</p>
  <a
    class:list={['sidebar__link', { 'is-active': active === 'tools/mgmt-sizing' }]}
    href={sizerHref}
    aria-current={active === 'tools/mgmt-sizing' ? 'page' : undefined}
  >
    <i class="fa-solid fa-calculator sidebar__icon" aria-hidden="true"></i>
    <span class="sidebar__text">
      <span class="sidebar__step">Interactive</span>
      <span class="sidebar__label">Sizing calculator</span>
    </span>
  </a>
  <a
    class:list={['sidebar__link', { 'is-active': active === 'tools/deployment-plan' }]}
    href={planExportHref}
    aria-current={active === 'tools/deployment-plan' ? 'page' : undefined}
  >
    <i class="fa-solid fa-sitemap sidebar__icon" aria-hidden="true"></i>
    <span class="sidebar__text">
      <span class="sidebar__step">Interactive</span>
      <span class="sidebar__label">Deployment Plan Export</span>
    </span>
  </a>
  <a
    class:list={['sidebar__link', { 'is-active': active === 'tools/plan-tracker' }]}
    href={planTrackerHref}
    aria-current={active === 'tools/plan-tracker' ? 'page' : undefined}
  >
    <i class="fa-solid fa-bars-progress sidebar__icon" aria-hidden="true"></i>
    <span class="sidebar__text">
      <span class="sidebar__step">Interactive</span>
      <span class="sidebar__label">Deployment Tracker</span>
    </span>
  </a>

  <p class="sidebar__eyebrow itq-eyebrow sidebar__eyebrow--spaced">Example</p>
  <a class="sidebar__link" href={sampleHref}>
    <i class="fa-solid fa-file-lines sidebar__icon" aria-hidden="true"></i>
    <span class="sidebar__text">
      <span class="sidebar__step">Rainpole</span>
      <span class="sidebar__label">Worked Step 1 plan</span>
    </span>
  </a>
</aside>
